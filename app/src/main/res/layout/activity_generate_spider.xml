<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/sv_output">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Spider Generator"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- AI API 配置 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI API 配置"
            android:textSize="18sp"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/et_api_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="API 地址 (如 https://api.openai.com)"
            android:inputType="textUri" />

        <EditText
            android:id="@+id/et_api_key"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="API Key"
            android:inputType="textPassword" />

        <EditText
            android:id="@+id/et_model"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Model (如 gpt-4, deepseek-chat)" />

        <!-- 网站代码输入 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="网站代码/API 信息"
            android:textSize="18sp"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/et_website_code"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:hint="请粘贴网站源代码或 API 信息..."
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:scrollbars="vertical" />

        <!-- 密码门禁选项 -->
        <LinearLayout
            android:id="@+id/ll_password_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="#F5F5F5">

            <CheckBox
                android:id="@+id/cb_add_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="添加密码门禁"
                android:checked="false" />

            <Button
                android:id="@+id/btn_toggle_password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="设置密码" />
        </LinearLayout>

        <!-- 按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btn_generate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="生成爬虫" />

            <Button
                android:id="@+id/btn_reset"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="重置"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- 状态显示 -->
        <ProgressBar
            android:id="@+id/pb_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="等待输入..."
            android:textColor="#666" />

    </LinearLayout>
</ScrollView>
